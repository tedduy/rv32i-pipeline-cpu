[tasks]
bmc
cover

[options]
multiclock on
bmc: mode bmc
bmc: depth 40
cover: mode cover
cover: depth 40

[engines]
smtbmc boolector

[script]
read -formal -sv \
@RTL_BASENAMES@
    rv32i_core_protocol.sv
prep -top rv32i_core_protocol_formal
async2sync
dffunmap

[files]
@RTL_FILES@
verification/formal/protocol/rv32i_core_protocol.sv
