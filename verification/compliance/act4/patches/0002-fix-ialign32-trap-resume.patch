diff --git a/tests/env/rvtest_trap_handler.h b/tests/env/rvtest_trap_handler.h
index a5d3555..6cc07c0 100644
--- a/tests/env/rvtest_trap_handler.h
+++ b/tests/env/rvtest_trap_handler.h
@@ -1952,6 +1952,13 @@ sv_\__MODE__\()epc:
 
 adj_\__MODE__\()epc_rtn:
         // Advance xEPC past the trapping instruction by its true width.
+  #ifndef __riscv_compressed
+        // With fixed IALIGN=32 every instruction occupies four bytes. Looking
+        // at bits[1:0] of an illegal encoding such as 0x00000000 would
+        // incorrectly classify it as a 16-bit instruction and can trap-loop
+        // when xEPC[1] is read-only zero.
+        li      T2, 4
+  #else
         // Read the low halfword of the instruction at xEPC (T3), in the
         // addressing/permission context of the code that trapped, then
         // advance 4 (bits[1:0]==0b11) or 2 (compressed).
@@ -1982,6 +1989,7 @@ adj_\__MODE__\()epc_rtn:
         srli    T2, T2, 2                            // 1 if 32-bit, 0 if compressed
         addi    T2, T2, 1                            // 2 (32-bit) or 1 (compressed)
         slli    T2, T2, 1                            // advance = 4 or 2
+  #endif
         add     T3, T3, T2                           // next instruction (raw xEPC + width)
         csrw    CSR_XEPC, T3
 
